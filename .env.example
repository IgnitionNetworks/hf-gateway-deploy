# Docker image version tag — use 'latest' or pin to a specific release (e.g. v1.2.0)
VERSION=latest

# Internal port the backend listens on (host network mode — must not conflict with
# other services on this host). nginx proxies to this port; change here and in
# nginx/nginx.conf if 8765 is taken.
# IGNITION_BACKEND_PORT=8765
