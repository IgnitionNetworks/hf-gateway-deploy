# Docker image version tag — use 'latest' or pin to a specific release (e.g. v1.2.0)
VERSION=latest

# Internal port the backend listens on (host network mode — must not conflict with
# other services on this host). nginx proxies to this port; change here and in
# nginx/nginx.conf if 8765 is taken.
# IGNITION_BACKEND_PORT=8765

# GHCR credentials for Watchtower — required to pull the private gateway image.
# GHCR_USER is your GitHub username.
# GHCR_TOKEN is a GitHub Personal Access Token with read:packages scope.
# Generate one at: https://github.com/settings/tokens
GHCR_USER=
GHCR_TOKEN=

# Watchtower HTTP API token — gates the auto-update endpoint that the app calls
# (manual "Update now" + the scheduled daily update). Set to a long random string,
# e.g. `openssl rand -hex 32`. Must be non-empty for auto-update to work.
WATCHTOWER_TOKEN=
